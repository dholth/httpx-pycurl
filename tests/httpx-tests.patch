--- httpx_fresh/tests/conftest.py	2026-04-11 14:01:04.396153925 -0400
+++ httpx/tests/conftest.py	2026-04-11 13:57:52.634747616 -0400
@@ -285,3 +285,73 @@
     config = Config(app=app, lifespan="off", loop="asyncio")
     server = TestServer(config=config)
     yield from serve_in_thread(server)
+
+
+# Patch AsyncClient to use AsyncPyCurlTransport from httpx_pycurl
+_pycurl_patched = False
+
+
+def pytest_configure(config):
+    """Patch httpx.AsyncClient to use AsyncPyCurlTransport for asyncio tests."""
+    global _pycurl_patched
+    try:
+        from httpx_pycurl import AsyncPyCurlTransport
+
+        _original_init = httpx.AsyncClient.__init__
+
+        def patched_init(self, **kwargs):
+            # Apply original init first
+            _original_init(self, **kwargs)
+
+            # After initialization, check if running in asyncio and replace transport
+            # The transport will be used later when the event loop is running
+            import asyncio
+            import sys
+
+            # Check if we're in an asyncio-based test (pytest-asyncio or anyio with asyncio)
+            # We can't reliably detect this at init time, so we'll use a different approach
+            # Patch the _transport to be a lazy wrapper
+            pass
+
+        # Instead of patching __init__, patch the _send_single_request to use our transport
+        _original_send_single_request = httpx.AsyncClient._send_single_request
+
+        async def patched_send_single_request(self, request):
+            # Only use pycurl transport for asyncio, not for trio
+            import sys
+            import asyncio
+
+            # Check if we're in trio (sniffio would be better but it's optional)
+            try:
+                asyncio.get_running_loop()
+                # We're in asyncio, safe to use pycurl
+                in_asyncio = True
+            except RuntimeError:
+                # Not in asyncio, likely trio
+                in_asyncio = False
+
+            # Check if the current transport is the default and we should replace it
+            transport_name = type(self._transport).__name__
+            if in_asyncio and transport_name in (
+                "HTTPCoreAsyncTransport",
+                "AsyncHTTPTransport",
+            ):
+                try:
+                    # Replace with pycurl transport only if not already patched
+                    if not hasattr(self, "_pycurl_patched"):
+                        old_transport = self._transport
+                        self._transport = AsyncPyCurlTransport()
+                        self._pycurl_patched = True
+                except ImportError as e:
+                    pass
+
+            return await _original_send_single_request(self, request)
+
+        httpx.AsyncClient._send_single_request = patched_send_single_request
+        _pycurl_patched = True
+    except Exception as e:
+        # Debug: print any errors during patching
+        import traceback
+
+        traceback.print_exc()
+        pass
